#!/bin/sh

# shellcheck source=../scripts/management
. "$SNAP/bin/management"

handle_config() {
    # Check required config values are set
    if ! has_config_set; then
        return $?
    fi

    # Write out those values
    printf 'issuer: %s\nclient_id: %s\nscopes: %s\nredirect_url: %s\nca_url: %s\n' \
        "$(issuer)" "$(client_id)" "$(scopes)" "$(redirect_url)" "$(ca_url)" > "$SNAP_DATA/etc/config.yml"

    # Write out optional trusted_ca option
    if ca="$(trusted_ca)"; then
        printf 'trusted_ca: %s\n' "$ca" >> "$SNAP_DATA/etc/config.yml"
    fi

    # Set permissions on config file
    chmod 0644 "$SNAP_DATA/etc/config.yml"
}

handle_config
